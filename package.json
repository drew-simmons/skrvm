{
  "name": "skrvm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "build": "tsc && vite build",
    "dev": "vite",
    "fmt:ts": "oxfmt",
    "fmt:ts-check": "oxfmt --check",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fmt:rust-check": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "fmt": "pnpm fmt:ts && pnpm fmt:rust",
    "fmt:check": "pnpm fmt:ts-check && pnpm fmt:rust-check",
    "lint:ts": "oxlint",
    "lint:ts-fix": "oxlint --fix",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml",
    "lint:rust-fix": "cargo clippy --manifest-path src-tauri/Cargo.toml --fix --allow-dirty --allow-staged",
    "lint": "pnpm lint:ts && pnpm lint:rust",
    "lint:fix": "pnpm lint:ts-fix && pnpm lint:rust-fix",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
